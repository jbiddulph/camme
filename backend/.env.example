# --- Camme (FastAPI) — required for the API as it exists today ---
APP_NAME=Camme API
API_PREFIX=/api/v1
# Signing key for Camme-issued JWTs (register/login). Do not reuse Supabase keys here.
SECRET_KEY=change-this-camme-jwt-signing-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLAlchemy + psycopg3 DSN (use +psycopg, not postgresql:// alone)
# Local Supabase default is often port 54322; adjust to match `supabase status`.
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres
# Supabase Cloud / RDS: TLS is required. Either append ?sslmode=require to POSTGRES_DSN or set:
# POSTGRES_SSLMODE=require
# Prefer the direct/session connection (often port 5432) for dev; transaction pooler (6543) can break DDL.

# Set true locally to get HTML tracebacks on unexpected 500s (otherwise the response is plain "Internal Server Error").
DEBUG=false

REDIS_URL=redis://127.0.0.1:6379/0
LIVEKIT_URL=http://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
STRIPE_SECRET_KEY=sk_test_replace_me
# Browsers that talk to the API (Camme Go app + any dev frontend)
ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://localhost:3000

# Lovense (Standard JS SDK + getToken) — https://developer.lovense.com
# LOVENSE_TOKEN = Developer Token (server only). LOVENSE_PLATFORM = Website Name in developer dashboard.
LOVENSE_TOKEN=
LOVENSE_PLATFORM=
# Optional: Viewer JS startControl AES (https://developer.lovense.com/docs/cam-solutions/viewer-js)
LOVENSE_AES_KEY=
LOVENSE_AES_IV=

# --- Supabase local (optional today; for Storage/Auth/Admin API later) ---
# API_URL in Supabase docs = REST/Auth gateway — not the Camme API base URL.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-status
SUPABASE_JWT_SECRET=replace-with-jwt-secret-from-supabase-status
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_GRAPHQL_URL=http://127.0.0.1:54321/graphql/v1
SUPABASE_STUDIO_URL=http://127.0.0.1:54323
SUPABASE_STORAGE_S3_URL=http://127.0.0.1:54321/storage/v1/s3
SUPABASE_MAILPIT_URL=http://127.0.0.1:54324
SUPABASE_INBUCKET_URL=http://127.0.0.1:54324
SUPABASE_MCP_URL=http://127.0.0.1:54321/mcp
# If you use newer Supabase "publishable" / "secret" keys from the dashboard:
SUPABASE_PUBLISHABLE_KEY=replace-if-used
SUPABASE_SECRET_KEY=replace-if-used
SUPABASE_S3_PROTOCOL_ACCESS_KEY_ID=replace-if-used
SUPABASE_S3_PROTOCOL_ACCESS_KEY_SECRET=replace-if-used
SUPABASE_S3_PROTOCOL_REGION=local
