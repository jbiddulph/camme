PORT=8080
BACKEND_BASE_URL=http://localhost:8000
# Must match FastAPI API_PREFIX (default /api/v1). No quotes needed; quotes are stripped if present.
API_PREFIX=/api/v1

# Heroku (camme-web): set to your FastAPI app URL so /api/* proxies correctly, e.g.:
# BACKEND_BASE_URL=https://camme-api-xxxx.herokuapp.com
